{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Dictionary",
  "version": "0.1.0",
  "identifier": "com.example.dict",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Dictionary",
        "width": 400,
        "height": 600,
        "decorations": false,
        "dragDropEnabled": true,
        "center": true
      }
    ],
    "trayIcon": null,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
