{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri2template",
  "version": "0.1.0",
  "identifier": "com.example.tauri2template",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tauri2template",
        "width": 800,
        "height": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray_icon.png"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
